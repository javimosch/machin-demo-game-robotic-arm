// machin-demo-game-robotic-arm — tests/test_kinematics.src
// Headless unit tests for the simulation core (00_math + 01_armspec +
// 02_kinematics). Compiled WITHOUT any extern block, so it runs under
// `machin run` with no raylib. See tests/run_tests.sh.

var g_pass = 0
var g_fail = 0

func check(name, cond) {
    if cond {
        g_pass = g_pass + 1
        println("  PASS  " + name)
    } else {
        g_fail = g_fail + 1
        println("  FAIL  " + name)
    }
}

func approx(a, b, eps) (r) { r = false  if absf(a - b) <= eps { r = true } }
func vapprox(a, b, eps) (r) { r = false  if vdist(a, b) <= eps { r = true } }

// ── IK wrist round-trip: fk_wrist(ik_wrist_auto(W)) == W ──────────────────
func rt_wrist(name, wx, wy, wz) {
    w := Vec3{wx, wy, wz}
    j1, j2, j3, ok := ik_wrist_auto(w)
    p := fk_wrist(j1, j2, j3)
    check(name, ok)
    check(name + " round-trip", vapprox(p, w, 0.0001))
}

// ── IK pick round-trip: fk_tip(ik_pick(T)) == T (gripper points down) ─────
func rt_pick(name, tx, ty, tz) {
    t := Vec3{tx, ty, tz}
    j1, j2, j3, j4, ok := ik_pick(t)
    p := fk_tip(j1, j2, j3, j4)
    check(name, ok)
    check(name + " tip-on-target", vapprox(p, t, 0.0001))
    // tool points straight down  =>  cumulative pitch direction is world -Y
    check(name + " tool-down", approx(cos(deg2rad(j2 + j3 + j4)), 0.0 - 1.0, 0.0001))
}

func main() {
    println("=== kinematics tests ===")

    // --- forward kinematics sanity ---
    // arm straight up (all pitch 0): wrist directly above shoulder
    pu := fk_wrist(0.0, 0.0, 0.0)
    check("FK straight-up x≈0", approx(pu.x, 0.0, 0.0001))
    check("FK straight-up z≈0", approx(pu.z, 0.0, 0.0001))
    check("FK straight-up y=shoulder+L2+L3",
          approx(pu.y, SHOULDER_Y() + L2() + L3(), 0.0001))

    // --- base-yaw azimuth ---
    // target on +X  -> j1 ≈ 0 ; target on world -Z -> j1 ≈ +90
    ja, x2, x3, oka := ik_wrist(Vec3{1.8, 1.5, 0.0}, 1.0)
    check("azimuth +X -> j1≈0", approx(ja, 0.0, 0.001))
    jb, y2, y3, okb := ik_wrist(Vec3{0.0, 1.5, 0.0 - 1.8}, 1.0)
    check("azimuth -Z -> j1≈90", approx(jb, 90.0, 0.001))

    // --- IK wrist round-trips (both elbow branches) ---
    rt_wrist("wrist A", 1.5, 1.5, 0.0)
    rt_wrist("wrist B", 2.0, 0.8, 0.0)
    rt_wrist("wrist C", 1.2, 0.6, 1.0)
    rt_wrist("wrist D (-x,z)", 0.0 - 1.5, 1.0, 0.8)
    rt_wrist("wrist E low", 1.0, 0.3, 0.0 - 0.6)

    // --- full pick round-trips (gripper tip on table-height targets) ---
    rt_pick("pick bin", 0.0 - 2.0, 0.24, 0.40)
    rt_pick("pick tray", 2.0, 0.10, 0.50)
    rt_pick("pick center", 1.5, 0.10, 0.0)

    // --- out of reach: ok=false, arm extends to MAX_REACH toward target ---
    far := Vec3{5.0, 0.95, 0.0}
    fj1, fj2, fj3, fok := ik_wrist(far, 1.0)
    fp := fk_wrist(fj1, fj2, fj3)
    sh := Vec3{BASE_X(), SHOULDER_Y(), BASE_Z()}
    check("out-of-reach flagged", fok == false)
    check("out-of-reach extends to MAX_REACH",
          approx(vdist(fp, sh), MAX_REACH(), 0.01))

    // --- actuator: converge 0 -> 90 deg, respect vmax, settle ---
    jt := mk_joint(0.0)
    dt := 1.0 / 60.0
    vmax := ACT_VMAX(1)
    amax := ACT_AMAX(1)
    gain := ACT_GAIN(1)
    maxv := 0.0
    i := 0
    while i < 300 {
        jt = joint_step(jt, 90.0, dt, vmax, amax, gain)
        av := absf(jt.vel)
        if av > maxv { maxv = av }
        i = i + 1
    }
    check("actuator converges to target", approx(jt.angle, 90.0, 0.25))
    check("actuator stops (vel≈0)", absf(jt.vel) < 1.0)
    check("actuator honors vmax", maxv <= vmax + 0.001)
    check("actuator reports settled", joint_settled(jt, 90.0))

    // --- actuator: accel limit honored (first step can't exceed amax*dt) ---
    j0 := mk_joint(0.0)
    j1s := joint_step(j0, 90.0, dt, vmax, amax, gain)
    check("actuator honors amax on step 1", absf(j1s.vel) <= amax * dt + 0.001)

    // --- hydraulics: linkage length, derivative, flow cap, pressure ---
    spu := CylSpec{1.0, 1.0, 0.0, 1.0}
    check("cyl_len θ=0 -> 0", approx(cyl_len(0.0, spu), 0.0, 0.0001))
    check("cyl_len θ=90 -> √2", approx(cyl_len(90.0, spu), sqrt(2.0), 0.0001))
    check("cyl_len θ=180 -> 2", approx(cyl_len(180.0, spu), 2.0, 0.0001))

    spe := cyl_spec(2)
    th := 40.0
    num := (cyl_len(th + 0.01, spe) - cyl_len(th - 0.01, spe)) / 0.02   // per deg
    check("cyl_dlen_deg matches numerical", approx(cyl_dlen_deg(th, spe), num, 0.0001))

    dd := absf(cyl_dlen_deg(th, spe))
    expv := clampf(spe.qmax / dd, 10.0, 220.0)
    check("cyl_vmax = qmax/|dlen|", approx(cyl_vmax(th, spe), expv, 0.001))
    check("cyl_vmax >= floor", cyl_vmax(th, spe) >= 10.0)
    check("cyl_vmax <= ceil", cyl_vmax(th, spe) <= 220.0)

    // pressure: >= base, and rises as the arm extends horizontally
    p_tuck := cyl_pressure(1, 0.0, 0.0, 0.0, 0.0)            // arm straight up
    p_ext := cyl_pressure(1, 0.0, 0.0 - 90.0, 0.0, 0.0)      // arm horizontal
    check("pressure tucked ≈ base", approx(p_tuck, P_BASE(), 1.0))
    check("pressure >= base", p_ext >= P_BASE())
    check("pressure rises with extension", p_ext > p_tuck)

    // --- continuity-preserving IK: round-trip + fewer elbow flips ---
    c1, c2, c3, c4, cok := ik_pick_continuous(Vec3{2.0, 0.10, 0.50}, 0.0)
    cp := fk_tip(c1, c2, c3, c4)
    check("continuous pick ok", cok)
    check("continuous tip-on-target", vapprox(cp, Vec3{2.0, 0.10, 0.50}, 0.0001))
    check("continuous tool-down", approx(cos(deg2rad(c2 + c3 + c4)), 0.0 - 1.0, 0.0001))

    // at a target reachable by BOTH elbow branches, continuity follows whichever
    // branch the arm is already on (prev_j3) instead of snapping to a fixed one
    bf := Vec3{0.0 - 2.6, 0.30, 0.0 - 0.44}
    u1, u2, u3, u4, uok := ik_pick_continuous(bf, 0.0 - 90.0)   // arm on elbow-up
    d1, d2, d3, d4, dok := ik_pick_continuous(bf, 90.0)         // arm on elbow-down
    check("continuity keeps elbow-up branch", sgnf(u3) < 0.0)
    check("continuity keeps elbow-down branch", sgnf(d3) > 0.0)
    check("both branches reach the same target",
          vapprox(fk_tip(u1, u2, u3, u4), fk_tip(d1, d2, d3, d4), 0.0001))

    // --- layout: slots & bin positions ---
    check("dough count = slot count", N_DOUGH() == N_SLOTS())
    s0 := slot_pos(0)
    s5 := slot_pos(5)
    check("slot rest height = tray", approx(s0.y, DOUGH_REST_TRAY(), 0.0001))
    check("slots are distinct", vdist(s0, s5) > 0.1)
    check("slot near tray x", approx(s0.x, TRAY_X(), 0.6) == true)
    b0 := bin_pos(0)
    b5 := bin_pos(5)
    check("bin rest height", approx(b0.y, DOUGH_REST_BIN(), 0.0001))
    check("bin positions distinct", vdist(b0, b5) > 0.1)

    // --- task: dough set, grasp/release, gravity settle ---
    ds := mk_dough_set()
    check("dough set size", len(ds) == N_DOUGH())
    check("dough start in bin (state 0)", ds[0].state == 0)
    check("dough start at bin pos", vapprox(ds[0].pos, bin_pos(0), 0.0001))

    gd := dough_grasp(ds[0])
    check("grasp -> state 1", gd.state == 1)
    rd := dough_release(gd)
    check("release -> state 2", rd.state == 2)

    // a released ball above the tray falls and settles in its slot
    fall := Dough{Vec3{TRAY_X(), 1.0, 0.0}, Vec3{0.0, 0.0, 0.0}, 2, 0}
    miny := 999.0
    fi := 0
    while fi < 200 {
        fall = dough_fall(fall, 1.0 / 60.0)
        if fall.pos.y < miny { miny = fall.pos.y }
        fi = fi + 1
    }
    check("dough lands (state 3)", fall.state == 3)
    check("dough rests at tray height", approx(fall.pos.y, DOUGH_REST_TRAY(), 0.0001))
    check("dough never sinks below rest", miny >= DOUGH_REST_TRAY() - 0.0001)

    // a ball still in the bin is untouched by gravity
    still := dough_fall(ds[1], 1.0 / 60.0)
    check("in-bin dough unaffected by gravity", vapprox(still.pos, ds[1].pos, 0.0001))

    println("=== summary ===")
    println("PASS " + str(g_pass) + "   FAIL " + str(g_fail))
    if g_fail == 0 {
        println("ALL TESTS PASSED")
    } else {
        println("THERE WERE FAILURES")
    }
}
